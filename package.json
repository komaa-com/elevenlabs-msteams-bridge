{
  "name": "@komaa/elevenlabs-msteams-bridge",
  "version": "0.7.0",
  "description": "Bridge Microsoft Teams voice/video calls to an ElevenLabs Agent. Terminates the OpenClawBridge worker wire protocol on one side and the ElevenLabs Agent WebSocket on the other.",
  "keywords": [
    "elevenlabs",
    "microsoft-teams",
    "voice",
    "agent",
    "websocket",
    "bridge",
    "telephony",
    "conversational-ai"
  ],
  "license": "MIT",
  "author": "Komaa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/komaa-com/elevenlabs-msteams-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/komaa-com/elevenlabs-msteams-bridge/issues"
  },
  "homepage": "https://github.com/komaa-com/elevenlabs-msteams-bridge#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "elevenlabs-msteams-bridge": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
