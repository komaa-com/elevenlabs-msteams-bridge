# basic-bridge example configuration. Copy to .env and fill in.
# The example runs with `npm start` (node --env-file=.env index.mjs).

# --- required ---

# Your ElevenLabs API key (server-side only; never sent to the Teams side).
ELEVENLABS_API_KEY=sk_...

# The ElevenLabs agent that answers calls (Agents dashboard -> your agent -> ID).
ELEVENLABS_AGENT_ID=agent_...

# The shared secret from your StandIn identity. Pairing at standin.komaa.com
# issues it; both sides must hold the exact same value or the WebSocket
# handshake is rejected with 401.
WORKER_SHARED_SECRET=change-me

# --- common options ---

# Listen address for the WebSocket server StandIn dials into.
PORT=8080
BIND=0.0.0.0

# Deterministic goodbye: with a voice id set, time-limit goodbyes are spoken as
# the EXACT configured text via standalone TTS (recommended). Without it, the
# agent itself is asked to say goodbye (wording may vary).
#EL_TTS_VOICE_ID=

# Bridge-side hard cap per call, in minutes (fractional ok). 0 = disabled.
# On expiry the bridge speaks GOODBYE_TEXT, lets it play out, then ends the call.
MAX_CALL_MINUTES=0
#GOODBYE_TEXT=I'm sorry, we've reached the time limit for this call. Goodbye!

# Vision path 2 for the `look` client tool: any OpenAI-compatible
# chat-completions endpoint with image input. (This example overrides vision
# with a code hook in index.mjs; these apply if you remove that hook.)
#VISION_API_URL=https://api.openai.com/v1/chat/completions
#VISION_API_KEY=
#VISION_MODEL=gpt-4o-mini

# Regional ElevenLabs host, for latency + data residency. One of:
# api.elevenlabs.io (default) | api.us.elevenlabs.io |
# api.eu.residency.elevenlabs.io | api.in.residency.elevenlabs.io | api.sg.residency.elevenlabs.io
EL_HOST=api.elevenlabs.io

# Localized greeting / spoken AI disclosure (first_message override; the agent's
# security settings must allowlist the override or ElevenLabs rejects it).
#EL_FIRST_MESSAGE=Hello! You are talking to an AI assistant.

# Log level: debug | info | warn | error
LOG_LEVEL=info
