# --- required ---
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_AGENT_ID=agent_...
# the shared secret from your StandIn identity (pairing issues it); must match exactly
WORKER_SHARED_SECRET=change-me

# --- optional ---
PORT=8080
BIND=0.0.0.0
# regional pin: api.elevenlabs.io | api.us.elevenlabs.io | api.eu.residency.elevenlabs.io | api.in.residency.elevenlabs.io | api.sg.residency.elevenlabs.io
EL_HOST=api.elevenlabs.io
# environment-specific agent resolution (dev/staging alongside production)
#EL_ENVIRONMENT=production
# localized greeting / spoken disclosure (first_message override; must be allowlisted on the agent)
#EL_FIRST_MESSAGE=
# pin an agent branch per deployment
#EL_AGENT_BRANCH_ID=
# enables the deterministic governor goodbye via standalone TTS
#EL_TTS_VOICE_ID=
EL_TTS_MODEL_ID=eleven_turbo_v2_5
# NOTE: the audio format is fixed at pcm_16000 by design (no-transcode contract);
# the bridge validates the agent's in/out format at call start and logs an error on mismatch
# bridge-side call governor: hard cap in minutes (fractional ok); 0 = disabled
MAX_CALL_MINUTES=0
#GOODBYE_TEXT=I'm sorry, we've reached the time limit for this call. Thank you for calling, goodbye!
# grace before session.end when the goodbye duration is unknown (user_message fallback)
GOODBYE_GRACE_MS=8000
# vision path 2 (describe-then-answer): any OpenAI-compatible chat-completions endpoint with image input
#VISION_API_URL=https://api.openai.com/v1/chat/completions
#VISION_API_KEY=
#VISION_MODEL=gpt-4o-mini
# HMAC replay window in ms (worker documents ±60s)
HMAC_FRESHNESS_MS=60000
# DoS guards (0 = built-in defaults: 64 / 8 / 10000)
MAX_CONNECTIONS=0
MAX_CONNECTIONS_PER_IP=0
PRE_START_TIMEOUT_MS=0
# EL_HOST is restricted to *.elevenlabs.io so the API key can't be sent elsewhere;
# set only for a deliberate trusted proxy/test host
#EL_HOST_ALLOW_ANY=true
# log EL transcripts (still gated on Teams recording.status == "active")
LOG_TRANSCRIPTS=false
LOG_LEVEL=info
